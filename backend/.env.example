# StackRadar Backend — Environment Variables
# Copy this file to .env and fill in your keys

# Required — GitHub Personal Access Token (for repo stats)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Required — Groq API Key (for AI sentiment analysis)
# Get one at: https://console.groq.com
GROQ_API_KEY=

# Optional — YouTube Data API v3 key (for learning-resource discovery)
# Get one at: https://console.cloud.google.com -> enable "YouTube Data API v3"
# Without it, /tools/{slug}/resources still returns curated platform links and
# scoped searches, and reports videos_live=false so the UI says so honestly.
YOUTUBE_API_KEY=

# Clerk publishable key — the SAME public value as the frontend's
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY (pk_test_... / pk_live_...). Public, not a
# secret. Set this to turn ON server-side verification of /progress: the user
# id is then taken from the signed session token, not trusted from the client.
# Leave empty for local dev (endpoints fall back to a client-supplied id).
CLERK_PUBLISHABLE_KEY=

# Daily nudge (retention). Set RESEND_API_KEY to actually send the daily
# "your next lesson" email to opted-in users; leave empty and the batch runs as
# a safe no-op (reports what it would send, sends nothing). Get a key at
# https://resend.com. DIGEST_FROM must be a verified sender; SITE_URL is used
# in the email's links. Trigger the batch from an external daily cron:
#   POST /api/v1/admin/send-daily-digests  with header X-Admin-Key: <ADMIN_API_KEY>
RESEND_API_KEY=
DIGEST_FROM=StackRadar <onboarding@resend.dev>
SITE_URL=http://localhost:3000

# Optional — Admin key for manual scrape trigger (POST /api/v1/admin/scrape)
ADMIN_API_KEY=

# Optional — Database URL (auto-set by Docker; leave empty for local SQLite)
# DATABASE_URL=postgresql://stackradar:stackradar_pass@localhost:5432/stackradar
